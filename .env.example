# Copy this file to .env and adjust as needed. Sensible defaults are used
# for anything you leave out, so a bare `cp .env.example .env` already works.

# --- Database ---
# Default: local SQLite file. For deployment, point this at Postgres, e.g.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./ticketing.db

# --- Auth ---
JWT_SECRET=change-this-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=120

# --- Seat hold / waitlist timing ---
SEAT_HOLD_TTL_MINUTES=10
WAITLIST_OFFER_TTL_MINUTES=15
RELEASE_SCHEDULER_INTERVAL_SECONDS=15

# --- Email delivery ---
# "console" (default): no credentials needed. Emails are saved as .html
#                       files under sent_emails/ so you can inspect them.
# "smtp": sends real email. Fill in the SMTP_* values below.
EMAIL_BACKEND=console
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-address@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=no-reply@cinebook.example

# --- App ---
# Used to build the waitlist-offer links sent in emails. Set this to your
# deployed URL (e.g. https://cinebook.onrender.com) in production.
BASE_URL=http://127.0.0.1:8000
